# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# ── Backend ───────────────────────────────────────────────────────────────────

# JWT signing secret — use a long random string in production
# Generate one: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-long-random-string-in-production

# MongoDB connection URI
# Docker Compose (default — uses the mongodb service name):
MONGODB_URI=mongodb://mongodb:27017
# MongoDB Atlas:
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority

# MongoDB database name
DB_NAME=mini_ros

# Keeps Python logs visible in Docker immediately
PYTHONUNBUFFERED=1

# ── Frontend (Vite — must keep VITE_ prefix) ──────────────────────────────────

# URL the browser uses to reach the backend REST API
VITE_API_URL=http://localhost:8000

# URL the browser uses for the live WebSocket connection
VITE_WS_URL=ws://localhost:8000/ws

# ── Robot edge agent ──────────────────────────────────────────────────────────

# URL the robot container uses to reach the backend
# Uses Docker service name so it resolves inside the compose network
CLOUD_URL=http://backend:8000
